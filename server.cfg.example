# ============================================================================
# server.cfg.example — hardened reference server.cfg
#
# This file is a REFERENCE only. The live server.cfg is generated by the
# txAdmin Qbox recipe; this example documents the values we want it tuned to
# and the load order we expect. Diff your live server.cfg against this file
# after a recipe deploy and reconcile any drift.
#
# Secrets (sv_licenseKey, steam_webApiKey, DB credentials, …) MUST be managed
# by txAdmin's secret store and MUST NOT be committed to this repo.
# ============================================================================

# ---------------------------------------------------------------------------
# Network endpoints
# ---------------------------------------------------------------------------
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"

# Hide raw client endpoints from the server browser / status queries.
sv_endpointprivacy true

# ---------------------------------------------------------------------------
# Slots & game build
# ---------------------------------------------------------------------------
sv_maxclients 48

# Pin the game build. Set this to the current Cfx-recommended build for Qbox.
# Update when Cfx publishes a new recommended build. CHANGEME on each bump.
sv_enforceGameBuild 3258

# OneSync is required by Qbox.
set onesync on

# ---------------------------------------------------------------------------
# Server identity
# ---------------------------------------------------------------------------
sv_hostname "gtarp — Qbox RP (dev)"
sv_projectName "gtarp"
sv_projectDesc "Qbox-based roleplay server"
locale "en-US"
load_server_icon icon.png

# Steam tag list shown in the server browser.
sets tags "roleplay, qbox, whitelist"
sets locale "en-US"

# ---------------------------------------------------------------------------
# Secrets — DO NOT COMMIT REAL VALUES
# ---------------------------------------------------------------------------
# The two lines below are managed by txAdmin (or your secret store). They are
# shown here for documentation only; never paste real keys into this repo.
#
# sv_licenseKey   "CHANGEME_TXADMIN_MANAGED"
# set steam_webApiKey "CHANGEME_TXADMIN_MANAGED"

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# oxmysql connection string. Real credentials belong in a secret-managed
# convar; this placeholder documents the expected format only.
set mysql_connection_string "mysql://user:CHANGEME@127.0.0.1:3306/qbox?charset=utf8mb4"

# ---------------------------------------------------------------------------
# Resource load order
# ---------------------------------------------------------------------------
# Core libraries first.
ensure ox_lib
ensure oxmysql
ensure ox_target
ensure ox_inventory

# Qbox framework core.
ensure qbx_core

# Framework resources (qbx_management, qbx_vehicles, qbx_garages, qbx_police,
# qbx_ambulancejob, etc.) are pulled in by the txAdmin recipe and should be
# ensured here in dependency order. Keep that block above the custom layer.

# Custom layer — must be last so it can depend on everything above.
# custom.cfg ensures server_identity then server_base and registers
# the ACE allow for /coords (see custom.cfg).
exec custom.cfg

# ---------------------------------------------------------------------------
# ACE permissions (admin example)
# ---------------------------------------------------------------------------
# Replace CHANGEME with a real identifier (license:, steam:, fivem:, discord:)
# for each admin. Keep this list short and audited.
#
# The custom layer also grants `command.coords` to group.admin from
# custom.cfg, so any principal mapped to group.admin here will be able to
# run /coords once the layer is loaded.
add_ace group.admin command       allow
add_ace group.admin command.quit  deny
add_principal identifier.license:CHANGEME group.admin
